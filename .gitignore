# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
e2e/fixtures/.auth.json
e2e/fixtures/.portal-auth.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local dev artifacts
.playwright-mcp/
/*.png

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
/lib/generated/_tmp_prisma
/prisma/_gen_tmp.prisma
# stray dirs left by sandboxed builds where unlink/rmdir is blocked by the mount
/sessions

# machine-local agent settings
.claude/settings.local.json
.claude/worktrees/
.next-build/
.next-m4build/
tmp/

/test-results/
/playwright-report/
